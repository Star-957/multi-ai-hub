# Copy this file to .env and fill in at least two providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Current defaults as of 2026-06-21; all can be overridden.
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
# Built-in OpenAI image generation is advertised to agents ONLY when this is "true".
# OpenAI API is 429/dead as of 2026-06, so it defaults OFF to stop agents wasting a tool
# round on a dead provider. Set to true when OpenAI image works again.
OPENAI_IMAGE_ENABLED=false
ANTHROPIC_MODEL=claude-opus-4-8
CLAUDE_TRANSPORT=cli
CLAUDE_EFFORT=max
GEMINI_MODEL=gemini-3.5-flash
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:30b
# Fast local sanity seat (ask_llama_fast). Default qwen3:8b = the installed fast model.
# Change to llama3.2:latest only if you have actually pulled it (`ollama pull llama3.2`).
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_DEEPSEEK_MODEL=deepseek-r1:70b

# Optional council seats. They stay dormant until the matching API key is set.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GLM_API_KEY=
GLM_MODEL=glm-5.2
# NVIDIA NIM — free OpenAI-compatible cloud seat (build.nvidia.com, nvapi- key, ~40 req/min).
# Dormant until NVIDIA_API_KEY is set; then ask_nvidia registers and it joins the quick council.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Local-only by default. Do not bind publicly without adding authentication.
HOST=127.0.0.1
PORT=8787
MAX_DELEGATION_DEPTH=3
MAX_TOOL_ROUNDS=6
MAX_OUTPUT_TOKENS=4096
